---
import fs from "node:fs";
import path from "node:path";
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav.astro";
import Footer from "@/components/footer.astro";

const albumPublicDir = "/FavPic";
const albumSourceDir = path.join(process.cwd(), "public", "FavPic");
const imagePattern = /\.(avif|gif|jpe?g|png|webp)$/i;

const albumPhotos = fs.existsSync(albumSourceDir)
  ? fs
      .readdirSync(albumSourceDir)
      .filter((file) => imagePattern.test(file))
      .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" }))
      .map((file, index) => ({
        src: `${albumPublicDir}/${file}`,
        alt: `Album photo ${index + 1}`,
      }))
  : [];
---

<Layout title="Album | Jason's Manor">
  <Nav />
  <main class="album-page text-[var(--white)] pt-24 md:pt-28 pb-16">
    <section class="max-w-6xl mx-auto px-4 md:px-6">
      <h2 class="text-lg text-[var(--sec)] mb-2">Visual notes</h2>
      <h1 class="text-4xl md:text-5xl font-medium mb-8 md:mb-10">Album</h1>

      {
        albumPhotos.length === 0 ? (
          <p class="text-[var(--white-icon)] border border-dashed border-white/20 rounded-xl p-4">
            未在 <code>public/FavPic</code> 检测到图片。请把图片放进该目录，Album 会自动读取并展示。
          </p>
        ) : (
          <div class="wrapper">
            <div class="boxes-container">
              {albumPhotos.map((photo, index) => (
                <button class="box box-content" type="button" style={`background-image:url('${photo.src}')`} aria-label={photo.alt} data-index={index}></button>
              ))}
            </div>
          </div>
        )
      }
    </section>
  </main>
  <Footer />

  <div class="modal" aria-hidden="true">
    <div class="overlay"></div>
    <div class="content"></div>
  </div>
</Layout>

<style>
  .wrapper {
    width: 100%;
  }

  .boxes-container {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    width: 100%;
    margin: 0 auto;
  }

  .box {
    width: 100%;
    aspect-ratio: 1;
    padding: 0.35rem;
    border: 1px dashed #ffffff2d;
    border-radius: 12px;
    background-color: #151515;
    background-position: center;
    background-size: cover;
    cursor: pointer;
    outline: none;
    transition: transform 0.2s ease;
    will-change: transform;
  }

  .box:hover,
  .box:focus-visible {
    transform: translateY(-2px);
  }

  .modal {
    width: 100%;
    height: 100vh;
    position: fixed;
    inset: 0;
    background-color: transparent;
    z-index: 1100;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
  }

  .modal .content {
    height: min(80vh, 720px);
    aspect-ratio: 4 / 5;
    position: relative;
    z-index: 1101;
    max-width: 90vw;
  }

  .modal .content .box {
    width: 100%;
    height: 100%;
    box-shadow: 0 20px 60px #00000080;
    border-radius: 16px;
    border-style: solid;
    transform: none;
  }

  .overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background-color: black;
    opacity: 0;
  }

  @media (max-width: 1024px) {
    .boxes-container {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .boxes-container {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.6rem;
    }

    .box {
      padding: 0.28rem;
    }

    .modal .content {
      width: min(88vw, 400px);
      height: auto;
      max-height: 85vh;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .box {
      transition: none;
    }
  }
</style>

<script type="module" is:inline>
  import { gsap } from "https://cdn.jsdelivr.net/npm/gsap@3.12.5/+esm";
  import { Flip } from "https://cdn.jsdelivr.net/npm/gsap@3.12.5/Flip/+esm";

  gsap.registerPlugin(Flip);

  const modal = document.querySelector(".modal");
  const modalContent = modal?.querySelector(".content");
  const modalOverlay = modal?.querySelector(".overlay");
  const boxes = gsap.utils.toArray(".boxes-container .box");

  let activeBox;
  let activeIndex = -1;
  const boxesContainer = document.querySelector(".boxes-container");

  const closeModal = () => {
    if (!modal || !modalContent || !modalOverlay || !activeBox) return;

    if (!boxesContainer) return;

    const state = Flip.getState(activeBox);
    const siblings = boxesContainer.querySelectorAll(".box");
    const anchor = siblings[activeIndex] ?? null;

    if (anchor) {
      boxesContainer.insertBefore(activeBox, anchor);
    } else {
      boxesContainer.appendChild(activeBox);
    }

    activeBox = undefined;
    activeIndex = -1;

    gsap.to([modal, modalOverlay], {
      autoAlpha: 0,
      ease: "power2.inOut",
      duration: 0.25,
      overwrite: "auto",
    });

    Flip.from(state, {
      duration: 0.45,
      ease: "power2.inOut",
      absolute: true,
      simple: true,
      onComplete: () => gsap.set(boxes, { clearProps: "zIndex" }),
    });
  };

  const openModal = (box) => {
    if (!modal || !modalContent || !modalOverlay) return;

    const state = Flip.getState(box);
    modalContent.appendChild(box);
    activeBox = box;
    activeIndex = Number(box.dataset.index ?? -1);

    gsap.set(modal, { autoAlpha: 1 });

    Flip.from(state, {
      duration: 0.45,
      absolute: true,
      simple: true,
      ease: "power2.out",
    });

    gsap.to(modalOverlay, {
      autoAlpha: 0.65,
      duration: 0.25,
      overwrite: "auto",
    });
  };

  boxes.forEach((box) => {
    box.addEventListener("click", () => {
      if (activeBox) {
        closeModal();
      } else {
        openModal(box);
      }
    });
  });

  modalOverlay?.addEventListener("click", closeModal);

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeModal();
    }
  });
</script>
