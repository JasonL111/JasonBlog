---
import { getCollection, render } from "astro:content";

const blogEntries = await getCollection("blog");

const posts = (
  await Promise.all(
    blogEntries.map(async (entry) => {
      const { Content } = await render(entry);
      return {
        ...entry.data,
        Content,
      };
    })
  )
).sort((a, b) => b.date.getTime() - a.date.getTime());
---

<section id="blog" class="py-16 border-t border-[#ffffff10] text-[var(--white)]">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2">My notes</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">Blog</h3>

    {
      posts.length === 0 ? (
        <p class="text-[var(--white-icon)]">
          把你的 Markdown 文件放到 <code>src/content/blog</code>，这里会自动显示。
        </p>
      ) : (
        <div class="space-y-8">
          {posts.map((post) => (
            <article class="blog-card">
              <header class="mb-4">
                <h4 class="text-2xl font-semibold">{post.title}</h4>
                <time class="text-sm text-[var(--white-icon)]">
                  {post.date.toLocaleDateString("zh-CN")}
                </time>
                {post.summary && (
                  <p class="mt-2 text-[var(--white-icon)]">{post.summary}</p>
                )}
              </header>
              <div class="blog-content">
                <post.Content />
              </div>
            </article>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .blog-card {
    background: #141414;
    border: 1px solid #ffffff14;
    border-radius: 16px;
    padding: 1.5rem;
  }

  .blog-content :global(h1),
  .blog-content :global(h2),
  .blog-content :global(h3) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    color: #ffffff;
  }

  .blog-content :global(p),
  .blog-content :global(li) {
    color: #d4d4d4;
    line-height: 1.75;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-left: 1.25rem;
  }

  .blog-content :global(code) {
    background: #232323;
    border-radius: 6px;
    padding: 0.1rem 0.35rem;
  }
</style>
