---
import { getCollection } from "astro:content";

const blogEntries = await getCollection("blog");

const posts = blogEntries
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((entry) => ({
    slug: entry.slug,
    ...entry.data,
    tags: entry.data.tags ?? [],
  }));

const allTags = [...new Set(posts.flatMap((post) => post.tags))];
---

<section class="py-16 text-[var(--white)]">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2">My notes</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">Blog</h3>

    <div class="mb-6 space-y-4">
      <input id="blog-search" class="search-input" type="text" placeholder="搜索标题、摘要或标签..." />

      <div class="flex flex-wrap gap-2">
        <button class="tag-btn active" data-tag="all">全部</button>
        {allTags.map((tag) => (
          <button class="tag-btn" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </div>

    {
      posts.length === 0 ? (
        <p class="text-[var(--white-icon)]">
          把你的 Markdown 文件放到 <code>src/content/blog</code>，这里会自动显示。
        </p>
      ) : (
        <>
          <div id="blog-empty" class="hidden text-[var(--white-icon)]">没有匹配的文章。</div>
          <div class="space-y-4" id="blog-post-list">
            {posts.map((post) => (
              <article
                class="blog-list-item"
                data-title={post.title.toLowerCase()}
                data-summary={(post.summary ?? "").toLowerCase()}
                data-tags={post.tags.join(",").toLowerCase()}
              >
                <h4>
                  <a class="blog-link" href={`/blog/${post.slug}`}>
                    {post.title}
                  </a>
                </h4>
                <time class="text-sm text-[var(--white-icon)] block mt-1">
                  {post.date.toLocaleDateString("zh-CN")}
                </time>
                {post.summary && (
                  <p class="mt-2 text-[var(--white-icon)]">{post.summary}</p>
                )}
                {post.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {post.tags.map((tag) => (
                      <span class="post-tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </article>
            ))}
          </div>
        </>
      )
    }
  </div>
</section>

<script>
  let selectedTag = "all";

  function applyFilters() {
    const input = document.getElementById("blog-search") as HTMLInputElement | null;
    const query = input?.value.toLowerCase().trim() ?? "";
    const cards = Array.from(document.querySelectorAll(".blog-list-item")) as HTMLElement[];

    let visibleCount = 0;

    cards.forEach((card) => {
      const title = card.dataset.title ?? "";
      const summary = card.dataset.summary ?? "";
      const tags = card.dataset.tags ?? "";

      const matchTag = selectedTag === "all" || tags.split(",").includes(selectedTag);
      const matchQuery =
        query.length === 0 || title.includes(query) || summary.includes(query) || tags.includes(query);

      const visible = matchTag && matchQuery;
      card.classList.toggle("hidden", !visible);
      if (visible) visibleCount += 1;
    });

    document.getElementById("blog-empty")?.classList.toggle("hidden", visibleCount !== 0);
  }

  document.addEventListener("DOMContentLoaded", () => {
    const input = document.getElementById("blog-search");
    input?.addEventListener("input", applyFilters);

    document.querySelectorAll(".tag-btn").forEach((button) => {
      button.addEventListener("click", () => {
        document.querySelectorAll(".tag-btn").forEach((btn) => btn.classList.remove("active"));
        button.classList.add("active");
        selectedTag = (button as HTMLElement).dataset.tag ?? "all";
        applyFilters();
      });
    });

    applyFilters();
  });
</script>

<style>
  .blog-list-item {
    background: #141414;
    border: 1px solid #ffffff14;
    border-radius: 14px;
    padding: 1rem 1.2rem;
  }

  .blog-link {
    color: #ffffff;
    font-size: 1.3rem;
    font-weight: 600;
    text-decoration: none;
  }

  .blog-link:hover {
    text-decoration: underline;
    color: var(--sec);
  }

  .search-input {
    width: 100%;
    background: #141414;
    border: 1px solid #ffffff1f;
    border-radius: 12px;
    padding: 0.7rem 0.9rem;
    color: #fff;
  }

  .tag-btn {
    background: #171717;
    border: 1px solid #ffffff1f;
    color: var(--white-icon);
    border-radius: 999px;
    padding: 0.35rem 0.8rem;
    font-size: 0.875rem;
  }

  .tag-btn.active {
    border-color: var(--sec);
    color: #fff;
  }

  .post-tag {
    border: 1px solid #ffffff24;
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    font-size: 0.8rem;
    color: var(--white-icon);
  }
</style>
